# Databricks App Configuration Template
# Copy this to app.yaml and fill in your values

command:
  [
    "sh",
    "-c",
    "pip install -r requirements.txt && npm install && npm run build && gunicorn --bind 0.0.0.0:8000 --workers 2 --timeout 120 api_server:app",
  ]

env:
  - name: DATABRICKS_HOST
    value: "https://YOUR_WORKSPACE.cloud.databricks.com/"
    
  - name: DATABRICKS_WAREHOUSE_ID
    value: "YOUR_WAREHOUSE_ID"
    
  - name: CATALOG
    value: "YOUR_CATALOG"
    
  - name: SCHEMA
    value: "investment_intel"

  - name: LAKEBASE_HOST
    value: "YOUR_LAKEBASE_HOST"
    
  - name: LAKEBASE_DATABASE
    value: "investment_intel_db"

  - name: VECTOR_SEARCH_ENDPOINT
    value: "YOUR_VECTOR_ENDPOINT"
    
  - name: LLM_MODEL_ORCHESTRATOR
    value: "databricks-gpt-oss-120b"
    
  - name: LLM_MODEL_RAG
    value: "databricks-claude-sonnet-4-5"

  - name: HEARTBEAT_INTERVAL_SECONDS
    value: "60"
    
  - name: AUTO_START_HEARTBEAT
    value: "false"

