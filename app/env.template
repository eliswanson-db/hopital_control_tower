# Environment variables for local development
# Copy to .env and fill in values

# Databricks workspace
DATABRICKS_HOST=https://YOUR_WORKSPACE.cloud.databricks.com/
DATABRICKS_TOKEN=YOUR_TOKEN
DATABRICKS_WAREHOUSE_ID=YOUR_WAREHOUSE_ID

# For service principal auth (Databricks Apps uses this)
# DATABRICKS_CLIENT_ID=
# DATABRICKS_CLIENT_SECRET=

# Unity Catalog
CATALOG=eswanson
SCHEMA=med_logistics_nba

# Lakebase
LAKEBASE_HOST=YOUR_LAKEBASE_HOST
LAKEBASE_DATABASE=med_logistics_nba_db

# Vector Search
VECTOR_SEARCH_ENDPOINT=eswanson_med_logistics_nba_vector_endpoint

# LLM Models
LLM_MODEL_ORCHESTRATOR=databricks-gpt-oss-120b
LLM_MODEL_RAG=databricks-claude-sonnet-4-5

# Heartbeat
HEARTBEAT_INTERVAL_SECONDS=60
AUTO_START_HEARTBEAT=false

